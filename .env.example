# Smart Green ENSIT — Variables d'environnement EXEMPLE
# Copier ce fichier en .env et remplir les valeurs réelles

# Base de données
DATABASE_URL=postgresql://sge_user:MOT_DE_PASSE_FORT@localhost:5432/smart_green

# IMPORTANT: Générer avec: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=VOTRE_CLE_SECRETE_JWT_MINIMUM_32_CARACTERES

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

APP_NAME=Smart Green ENSIT
FRONTEND_URL=http://localhost:3000
ENVIRONMENT=development
